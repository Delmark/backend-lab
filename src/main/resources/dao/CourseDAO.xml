<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="by.delmark.backendlab.dao.CourseDAO">

    <resultMap id="courseMap" type="by.delmark.backendlab.pojo.model.Course">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="director" column="director"/>
        <result property="releaseYear" column="release_year"/>
        <result property="rating" column="rating"/>
        <result property="available" column="available"/>
    </resultMap>

    <select id="getCourses" resultMap="courseMap">
        SELECT
            *
        FROM course
    </select>

    <select id="getCourseById" resultMap="courseMap">
        SELECT
            *
        FROM course
        WHERE id = #{id}
    </select>

    <insert id="insertCourse">
        INSERT INTO course (title, director, release_year, rating, available)
        VALUES (#{title}, #{director}, #{releaseYear}, #{rating}, #{available})
    </insert>

    <update id="updateCourse">
        UPDATE course
        SET
            title = #{course.title},
            director = #{course.director},
            release_year = #{course.releaseYear},
            rating = #{course.rating},
            available = #{course.available}
        WHERE id = #{id}
    </update>

    <update id="patchCourse">
        UPDATE course
        <set>
            <if test="course.title != null">
                title = #{course.title},
            </if>
            <if test="course.director != null">
                director = #{course.director},
            </if>
            <if test="course.releaseYear != null">
                release_year = #{course.releaseYear},
            </if>
            <if test="course.rating != null">
                rating = #{course.rating},
            </if>
            <if test="course.available != null">
                available = #{course.available}
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteCourse">
        DELETE FROM course
        WHERE id = #{id}
    </delete>

</mapper>