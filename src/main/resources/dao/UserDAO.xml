<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="by.delmark.backendlab.dao.UserDAO">

    <resultMap id="userMap" type="by.delmark.backendlab.pojo.model.User">
        <id property="id" column="id"/>
        <result property="login" column="login"/>
        <result property="password" column="hash_password"/>
        <result property="isActive" column="is_active"/>
    </resultMap>

    <select id="getByLogin" resultMap="userMap">
        SELECT
            *
        FROM users u
        WHERE u.login = #{login}
    </select>

    <insert id="saveUser">
        INSERT INTO users (login, hash_password)
        VALUES (#{login}, #{password})
        ON CONFLICT (login) DO NOTHING
    </insert>

</mapper>